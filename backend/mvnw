# ----------------------------------------------------------------------------
# Maven2 Start Up Shell Script
#
# Required ENV vars:
# ------------------
#   JAVA_HOME - location of a JDK home dir
#
# Optional ENV vars:
# ------------------
#   MAVEN_OPTS - parameters passed to the Java VM when running Maven
#     e.g. to debug Maven itself, use
#     set MAVEN_OPTS=-Xdebug -Xrunjdwp:transport=dt_socket,server=y,suspend=y,address=8000
#   MAVEN_SKIP_RC - flag to disable loading of mavenrc files
# ----------------------------------------------------------------------------

# Resolve any symlinks to the script path
PRG="$0"
while [ -h "$PRG" ] ; do
  ls=`ls -ld "$PRG"`
  link=`expr "$ls" : '.*-> \(.*\)$'`
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=`dirname "$PRG"`/"$link"
  fi
done

APP_HOME=`dirname "$PRG"`
APP_BASE_NAME=`basename "$0"`

# Download wrapper jar if not exists
WRAPPER_JAR="$APP_HOME/.mvn/wrapper/maven-wrapper.jar"
if [ ! -f "$WRAPPER_JAR" ]; then
    echo "[INFO] Downloading Maven Wrapper JAR..."
    # Simplified download logic
    curl -sL https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.1.0/maven-wrapper-3.1.0.jar -o "$WRAPPER_JAR" || \
    wget -q https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.1.0/maven-wrapper-3.1.0.jar -O "$WRAPPER_JAR"
fi

# Find the project base dir
MAVEN_PROJECTBASEDIR="$APP_HOME"
while [ ! -d "$MAVEN_PROJECTBASEDIR/.mvn" ]; do
  MAVEN_PROJECTBASEDIR=`dirname "$MAVEN_PROJECTBASEDIR"`
  if [ "$MAVEN_PROJECTBASEDIR" = "/" ]; then
    MAVEN_PROJECTBASEDIR="$APP_HOME"
    break
  fi
done

# Check JAVA_HOME
if [ -z "$JAVA_HOME" ]; then
  JAVACMD=java
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

# Start Maven
exec "$JAVACMD" \
  $MAVEN_OPTS \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
